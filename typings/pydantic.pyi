from typing import Any, Dict, Type, TypeVar

_T = TypeVar("_T", bound="BaseModel")

class BaseModel:
    def __init__(self, *args: Any, **kwargs: Any) -> None: ...

    @classmethod
    def model_validate(cls: Type[_T], *args: Any, **kwargs: Any) -> _T: ...

    def model_dump(self, *args: Any, **kwargs: Any) -> Dict[str, Any]: ...
    # legacy helper sometimes used in code
    def to_dict(self, *args: Any, **kwargs: Any) -> Dict[str, Any]: ...

ConfigDict: Any

def Field(*args: Any, **kwargs: Any) -> Any: ...

def computed_field(*args: Any, **kwargs: Any) -> Any: ...

def model_validator(*args: Any, **kwargs: Any) -> Any: ...

class ValidationError(Exception): ...

def field_validator(*args: Any, **kwargs: Any) -> Any: ...
