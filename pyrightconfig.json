{
  "typeCheckingMode": "strict",
  "include": ["src", "runbook", "tests", "typings"],
  "exclude": [
    "runbook/analysis",
    "**/node_modules",
    "**/__pycache__",
    "**/.*",
    ".venv"
  ],
  "venvPath": ".",
  "venv": ".venv",
  "stubPath": "typings",
  "reportMissingImports": true,
  "executionEnvironments": [
    {
      "root": ".",
      "extraPaths": ["src"]
    }
  ]
}
