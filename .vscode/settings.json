{
  "python.defaultInterpreterPath": "/home/owen/Documents/Dev/adrift/.venv/bin/python",
  "files.exclude": {
    "**/.venv": true,
    "**/__pycache__": true,
    "**/.cache": true,
    "**/*.cache": true,
    "**/*_cache": true,
    "**/.claude": true,
    "**/.claude/**": true
  },
  "editor.formatOnSave": true,
  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": "\\.py$",
        "notMatch": "(\\.venv|__pycache__|/\\.)",
        "cmd": "${workspaceFolder}/.venv/bin/python ${workspaceFolder}/runbook/quality/check_static.py --problems src runbook tests typings",
        "isAsync": true
      },
      {
        "match": "\\.py$",
        "notMatch": "(\\.venv|__pycache__|/\\.)",
        "cmd": "${workspaceFolder}/.venv/bin/python ${workspaceFolder}/runbook/quality/check_complexity.py src --ccn 5 --length 25 --params 4",
        "isAsync": true
      },
      {
        "match": "\\.py$",
        "notMatch": "(\\.venv|__pycache__|/\\.)",
        "cmd": "${workspaceFolder}/.venv/bin/python ${workspaceFolder}/runbook/quality/check_dead_code.py src",
        "isAsync": true
      },
      {
        "match": "config/.*\\.toml$",
        "cmd": "${workspaceFolder}/.venv/bin/python ${workspaceFolder}/runbook/quality/validate_configs.py --problems ${file}",
        "isAsync": true
      }
    ]
  },
  "cSpell.words": [
    "BYDAY",
    "dateutil",
    "dedupe",
    "dotenv",
    "DTSTART",
    "ffprobe",
    "flac",
    "libopus",
    "phash",
    "rrule",
    "rrules",
    "sponsorblock",
    "tobytes",
    "ytdlp"
  ],
  "python.testing.pytestArgs": [
    "tests"
  ],
  "python.testing.unittestEnabled": false,
  "python.testing.pytestEnabled": true,
  "python-envs.defaultEnvManager": "ms-python.python:poetry",
  "python-envs.defaultPackageManager": "ms-python.python:poetry",
}
