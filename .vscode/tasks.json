{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Ruff: Check",
      "type": "shell",
      "command": "make",
      "args": ["ruff-check"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": ["$ruff"]
    },
    {
      "label": "Ruff: Format Check",
      "type": "shell",
      "command": "make",
      "args": ["ruff-format-check"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Complexity: Lizard Check",
      "type": "shell",
      "command": "make",
      "args": ["check-complexity"],
      "group": "build",
      "presentation": {
        "echo": false,
        "reveal": "never",
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "problemMatcher": [
        {
          "owner": "lizard",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "pattern": {
            "regexp": "^(.*?):(\\d+):\\s+(error|warning):\\s+(.*)$",
            "file": 1,
            "line": 2,
            "severity": 3,
            "message": 4
          }
        }
      ],
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Import Boundaries: Check",
      "type": "shell",
      "command": "make",
      "args": ["check-import-boundaries"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": [
        {
          "owner": "import-boundaries",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "pattern": {
            "regexp": "^(.*?):(\\d+):\\s+(error|warning):\\s+(.*)$",
            "file": 1,
            "line": 2,
            "severity": 3,
            "message": 4
          }
        }
      ]
    },
    {
      "label": "Dead Code: Vulture Check",
      "type": "shell",
      "command": "make",
      "args": ["check-dead-code"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": [
        {
          "owner": "vulture",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "pattern": {
            "regexp": "^(.*?):(\\d+):\\s+(error|warning):\\s+(.*)$",
            "file": 1,
            "line": 2,
            "severity": 3,
            "message": 4
          }
        }
      ]
    },
    {
      "label": "Dead Code: Vulture Watch",
      "type": "shell",
      "command": "make",
      "args": ["check-dead-code"],
      "group": "build",
      "isBackground": true,
      "presentation": {
        "echo": false,
        "reveal": "never",
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "problemMatcher": [
        {
          "owner": "vulture",
          "fileLocation": ["relative", "${workspaceFolder}"],
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^\\[vulture\\] Scanning\\.\\.\\.$",
            "endsPattern": "^\\[vulture\\] Done\\.$"
          },
          "pattern": {
            "regexp": "^(.*?):(\\d+):\\s+(error|warning):\\s+(.*)$",
            "file": 1,
            "line": 2,
            "severity": 3,
            "message": 4
          }
        }
      ],
      "runOptions": {
        "runOn": "folderOpen"
      }
    },
    {
      "label": "Pytest: All (ignore filter_rules)",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath}",
      "args": [
        "-m",
        "pytest",
        "tests",
        "--ignore=tests/models/test_filter_rules.py"
      ],
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "Validate TOML",
      "type": "shell",
      "command": "make",
      "args": ["validate-configs"],
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      },
      "problemMatcher": [
        {
          "owner": "toml-validator",
          "fileLocation": "autoDetect",
          "pattern": {
            "regexp": "^(.*?):(\\d+):\\s*(.*?):\\s*(.*)$",
            "file": 1,
            "line": 2,
            "message": 4
          }
        }
      ]
    },
    {
      "label": "Validate TOML Watch",
      "type": "shell",
      "command": "make",
      "args": ["validate-configs"],
      "group": "build",
      "isBackground": true,
      "presentation": {
        "echo": false,
        "reveal": "never",
        "panel": "dedicated",
        "showReuseMessage": false
      },
      "problemMatcher": [
        {
          "owner": "toml-validator",
          "fileLocation": "autoDetect",
          "background": {
            "activeOnStart": true,
            "beginsPattern": "^\\[toml-validator\\] Scanning\\.\\.\\.$",
            "endsPattern": "^\\[toml-validator\\] Done\\.$"
          },
          "pattern": {
            "regexp": "^(.*?):(\\d+):\\s*(.*?):\\s*(.*)$",
            "file": 1,
            "line": 2,
            "message": 4
          }
        }
      ],
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
